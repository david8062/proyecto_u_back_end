generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////// Enums //////////////////////

enum level {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum ServiceType {
  CLASE_PERSONALIZADA
  REVISION_TAREA
  REVISION_PARCIAL
  TUTORIA_PROYECTO
}

enum DegreeLevel {
  BACHILLERATO
  PREGRADO
  ESPECIALIZACION
  MAESTRIA
  DOCTORADO
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

////////////////////// Auth & Users //////////////////////

model User {
  uniqueID         String   @id @default(uuid())
  primer_nombre    String   @db.VarChar(70)
  segundo_nombre   String?  @db.VarChar(70)
  primer_apellido  String   @db.VarChar(70)
  segundo_apellido String   @db.VarChar(70)
  cod_estudiante   String?  @db.VarChar(20)
  email            String   @unique @db.VarChar(70)
  has_password     String   @db.VarChar(256)

  faculty_uuid      String?
  rol_uuid          String
  id_password_reset String?

  faculty       Faculty?      @relation(fields: [faculty_uuid], references: [uniqueID])
  role          Rol           @relation(fields: [rol_uuid], references: [uniqueID])
  passwordReset PasswordReset?
  loginAttempts LoginAttemp[]
  profiles      Profile[]
}

model Rol {
  uniqueID  String           @id @default(uuid())
  name_rol  String           @db.VarChar(10)
  users     User[]
  permissions RolePermission[]
}

model RolePermission {
  uuid              String @id @default(uuid())
  view_permission   String @db.VarChar(10)
  action_permission String @db.VarChar(10)
  rol_id            String
  rol               Rol    @relation(fields: [rol_id], references: [uniqueID])
}

model PasswordReset {
  uniqueID     String   @id @default(uuid())
  fecha        DateTime
  old_password String
  new_password String
  ip           String
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [uniqueID])
}

model VerifyToken {
  uniqueID      String        @id @default(uuid())
  token         String        @db.VarChar(50)
  otp           String        @db.VarChar(6)
  loginAttempts LoginAttemp[]
}

model LoginAttemp {
  unique_ID   String      @id @default(uuid())
  ip          Int
  quantity    Int
  login_acces DateTime
  user_id     String
  id_token    String
  user        User        @relation(fields: [user_id], references: [uniqueID])
  verifyToken VerifyToken @relation(fields: [id_token], references: [uniqueID])
}

////////////////////// Academic Structure //////////////////////

model Faculty {
  uniqueID     String             @id @default(uuid())
  faculty_name String             @db.VarChar(30)
  users        User[]
  careers      UniversityCarrer[]
  categories   Category[]
}

model UniversityCarrer {
  uniqueID   String     @id @default(uuid())
  name       String     @db.VarChar(50)
  faculty_id String
  faculty    Faculty    @relation(fields: [faculty_id], references: [uniqueID])
  categories Category[]
}

model Category {
  uniqueID           String           @id @default(uuid())
  name               String           @db.VarChar(50)
  description        String           @db.VarChar(255)
  universityCarrerID String
  facultyID          String
  UniversityCarrer   UniversityCarrer @relation(fields: [universityCarrerID], references: [uniqueID])
  faculty            Faculty          @relation(fields: [facultyID], references: [uniqueID])
  subjects           TeacherSubject[]
}

////////////////////// Teacher Module — Phase 1 //////////////////////

model Profile {
  UniqueID                  String   @id @default(uuid())
  description               String?  @db.VarChar(500)
  experience                String?  @db.VarChar(500)
  profile_img               String?  @db.VarChar(255)
  specialization            String?  @db.VarChar(255)
  web_site                  String?  @db.VarChar(255)
  social_networks           String?  @db.VarChar(255)
  professional_certificates String?  @db.VarChar(255)
  is_verified               Boolean  @default(false)
  is_active                 Boolean  @default(true)
  user_id                   String
  user                      User     @relation(fields: [user_id], references: [uniqueID])

  education    Education[]
  subjects     TeacherSubject[]
  pricingPlans PricingPlan[]
  availability Availability[]
}

model Education {
  uniqueID    String      @id @default(uuid())
  degree      DegreeLevel
  institution String      @db.VarChar(100)
  field       String      @db.VarChar(100)
  start_year  Int
  end_year    Int?
  is_current  Boolean     @default(false)
  profile_id  String
  profile     Profile     @relation(fields: [profile_id], references: [UniqueID])
}

model TeacherSubject {
  uniqueID    String   @id @default(uuid())
  level       level
  description String?  @db.VarChar(255)
  profile_id  String
  category_id String
  profile     Profile  @relation(fields: [profile_id], references: [UniqueID])
  category    Category @relation(fields: [category_id], references: [uniqueID])
}

model PricingPlan {
  uniqueID     String      @id @default(uuid())
  service_type ServiceType
  price        Decimal     @db.Decimal(10, 2)
  description  String?     @db.VarChar(255)
  is_active    Boolean     @default(true)
  profile_id   String
  profile      Profile     @relation(fields: [profile_id], references: [UniqueID])
}

// Cada registro define un bloque semanal recurrente.
// slot_duration_minutes controla el tamaño de los turnos dentro del bloque,
// evitando solapamiento al hacer booking (ej: 8:00-17:00 con 60 min → slots 8:00, 9:00 … 16:00).
model Availability {
  uniqueID              String    @id @default(uuid())
  day_of_week           DayOfWeek
  start_time            String    @db.VarChar(5)
  end_time              String    @db.VarChar(5)
  slot_duration_minutes Int
  is_active             Boolean   @default(true)
  profile_id            String
  profile               Profile   @relation(fields: [profile_id], references: [UniqueID])
}
